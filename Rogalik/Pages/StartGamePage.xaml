<Page x:Class="Rogalik.Pages.StartGamePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Rogalik.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="StartGamePage">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Grid.RowSpan="9" Grid.ColumnSpan="16" Background="#2E2E2E" Margin="5" CornerRadius="10"/>
        <WrapPanel Grid.Column="6" Grid.Row="2" Grid.ColumnSpan="4" Grid.RowSpan="4" VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel >
                <TextBlock Text="Rogalik"  Foreground="#FF5555" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                <Button Content="Играть"  VerticalAlignment="Center" MinHeight="35" MinWidth="150" Click="Button_Click" Margin="10" Background="#FF5555" Foreground="White" FontWeight="Bold" FontSize="14" BorderThickness="4"/>
                <Button Content="Выбор персонажа" VerticalAlignment="Center" MinHeight="35" MinWidth="120" Click="Button_Click_1" Margin="10"  Background="#5555FF" Foreground="White" FontWeight="Bold" FontSize="14" BorderThickness="4"/>
                <Button Content="Об игре"  VerticalAlignment="Center" MinHeight="35" Click="Button_Click_3" Margin="10"  Background="#5555FF" Foreground="White" FontWeight="Bold" FontSize="14" BorderThickness="4"/>
            </StackPanel>
        </WrapPanel>
        <TextBlock Grid.Column="13" HorizontalAlignment="Right" Grid.Row="8" TextWrapping="Wrap" Grid.ColumnSpan="3"  Text="Версия 1.0" VerticalAlignment="Center" MinHeight="35" FontSize="16" MinWidth="100"/>
    </Grid>
</Page>
