<Page x:Class="Rogalik.Pages.ChooseHero"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Rogalik.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ChooseHero">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#3E3E3E" BorderBrush="#FF5555" BorderThickness="0,0,0,2"/>
        <TextBlock Text="Rogalik" Foreground="#FF5555" FontSize="24" FontWeight="Bold" Margin="0,0,20,0"/>
        <Border Grid.Row="1" Background="#3E3E3E"/>
        <WrapPanel Grid.Row="1" HorizontalAlignment="Left">
            <ScrollViewer>
                <StackPanel>
                <ListBox x:Name="HeroListBox" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#3E3E3E" CornerRadius="10" Padding="10" Margin="5" Width="240">
                                <StackPanel>
                                    <Border Background="#555" CornerRadius="5" Margin="0,0,0,10">
                                        <Image Height="160" Width="90" Source="{Binding Image}" Stretch="Uniform"/>
                                    </Border>
                                    <TextBlock Text="{Binding Name}" Foreground="#FF5555" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding MaxHP, StringFormat='Здоровье: {0}'}" Foreground="#FF5555" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding Damage.Name, StringFormat='Оружие: {0}'}" Foreground="#CCC" FontSize="16" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding Damage.Damage, StringFormat='Урон: {0}'}" Foreground="#CCC" FontSize="16" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding Protection.Name, StringFormat='Броня: {0}'}" Foreground="#CCC" FontSize="16" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding Protection.Protection, StringFormat='Защита: {0}'}" Foreground="#CCC" FontSize="16" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <Button Content="выбрать"  VerticalAlignment="Center" MinHeight="35" Margin="10"  Background="#5555FF" Foreground="White" FontWeight="Bold" FontSize="14" BorderThickness="4" Click="Button_Click"/>
            </StackPanel>
            </ScrollViewer>
</WrapPanel>
    </Grid>
</Page>
