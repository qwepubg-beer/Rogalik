<Page x:Class="Rogalik.Pages.ChooseHero"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Rogalik.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ChooseHero">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#3E3E3E" BorderBrush="#FF5555" BorderThickness="0,0,0,2"/>
        <TextBlock Text="Rogalik" Foreground="#FF5555" FontSize="24" FontWeight="Bold" Margin="0,0,20,0"/>
        <Border Grid.Row="1" Background="#3E3E3E"/>
        <WrapPanel Grid.Row="1" HorizontalAlignment="Left">
            <ScrollViewer>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Добро пожаловать в игру Rogalik. Для начала нужно выбрать персонажа (по дефолту Перминов). Игра предстовляет подземелье со врагами и боссами,при начале раунда 50/50 выпадает кейс или бой. В бою появляются от 1 до 3 врагов,  а каждий десятый раунд появляются боссы. В кейсе с 50% вероятностью падает зелье исциления, с 25% процентным шансом улучшение текущего оружия и брони, 25% новый предмет (оружие или броня). Игра завершается смертью персонажа." TextWrapping="Wrap" FontSize="16" Margin="5"></TextBlock>
                    <TextBlock Text="Разработчик: Perminov game studio" TextWrapping="Wrap" FontSize="16 " Margin="5"  HorizontalAlignment="Center"></TextBlock>
                    <TextBlock Text="Все права защищены" TextWrapping="Wrap" FontSize="16" Margin="5" HorizontalAlignment="Center"></TextBlock>
                    <Button Content="Далее"  VerticalAlignment="Center" MinHeight="35" Margin="10"  Background="#5555FF" Foreground="White" FontWeight="Bold" FontSize="14" BorderThickness="4" Click="Button_Click"/>
            </StackPanel>
            </ScrollViewer>
</WrapPanel>
    </Grid>
</Page>
