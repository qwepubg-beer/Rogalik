<Page x:Class="Rogalik.Pages.Game"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Rogalik.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Game">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="Red">
            <TextBlock Text="Этаж номер 1" FontSize="20" Margin="10" HorizontalAlignment="Right"/>
        </Border>
        <Border Grid.Row="1" Background="LightGray" Margin="5">
            <WrapPanel HorizontalAlignment="Center" Margin="5" VerticalAlignment="Center">
                <StackPanel Width="200" Height="300" Margin="0,0,10,0">
                    <Image Height="275"></Image>
                    <ProgressBar Height="25"/>
                </StackPanel>
                <ListBox x:Name="CPUList"  ScrollViewer.HorizontalScrollBarVisibility="Disabled" d:ItemsSource="{d:SampleData ItemCount=3} ">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel HorizontalAlignment="Center">
                                <Image Height="240" Width="175"  Source="{Binding basepartCPU.image}"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Padding="5" Text="{Binding name}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ProgressBar Height="25"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>
            </WrapPanel>
        </Border>
        <Border Grid.Row="2" Background="Red">
            <WrapPanel HorizontalAlignment="Center" Margin="5">
                <StackPanel Width="320" Height="60">
                    
                </StackPanel>
                <Button Content="Атака" Width="80" Height="40" Margin="5"/>
                <Button Content="Защита" Width="80" Height="40" Margin="5"/>
                <ListBox Name="Log" Width="255" Height="60"/>
            </WrapPanel>
        </Border>
    </Grid>
</Page>
